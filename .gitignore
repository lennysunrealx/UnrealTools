# -----------------------------------------------------------------------------
# Unreal Engine project generated files
# -----------------------------------------------------------------------------
/Binaries/
/DerivedDataCache/
/Intermediate/
/Saved/

# Plugin generated files
/Plugins/*/Binaries/
/Plugins/*/DerivedDataCache/
/Plugins/*/Intermediate/
/Plugins/*/Saved/

# Unreal generated solution / project files
/*.sln
/*.suo
/*.opensdf
/*.sdf
/*.VC.db
/*.VC.opendb
/.vs/
/.vsconfig

# -----------------------------------------------------------------------------
# IDE / editor user files
# -----------------------------------------------------------------------------
/.idea/
*.user
*.userosscache
*.sln.docstates
*.rsuser

# -----------------------------------------------------------------------------
# Build artifacts and debug symbols
# -----------------------------------------------------------------------------
*.obj
*.o
*.pch
*.ilk
*.ipdb
*.iobj
*.exp
*.lib
*.pdb
*.dll
*.exe
*.app

# Live Coding / hot reload artifacts
*.patch_*.dll
*.patch_*.pdb
*.modules

# -----------------------------------------------------------------------------
# Logs, crash dumps, temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
*.dmp

# -----------------------------------------------------------------------------
# Python generated files
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Operating system junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# User-specific Unreal config
# -----------------------------------------------------------------------------
/Config/DefaultEditorPerProjectUserSettings.ini
/Config/DefaultEditor.ini.tmp

# -----------------------------------------------------------------------------
# Root Content allow-list
#
# This repo intentionally ignores most root /Content files, then allows only the
# tool folders below. Plugin content under /Plugins/.../Content is not affected
# by this section.
# -----------------------------------------------------------------------------
/Content/*
!/Content/

# Keep selected root Content tool folders
!/Content/_Tools/
!/Content/_Tools/**

!/Content/BlueprintTools/
!/Content/BlueprintTools/**

!/Content/PythonTools/
!/Content/PythonTools/**
