# Ignore all Content by default
Content/*

# Re-open Content so selected subfolders can be tracked
!Content/

# Allow these folders themselves
!Content/_Tools/
!Content/_Tools/**

# Allow everything inside them
!Content/BlueprintTools/**
!Content/PythonTools/**